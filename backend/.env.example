APP_NAME=UniScheduleAI
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Pacific/Auckland

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=unischedule
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120

SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000
FRONTEND_URL=http://localhost:3000

# Optional NLP / LLM (OpenAI-compatible). Unset = rule-based parser only.
# Groq free tier example (https://console.groq.com):
#   OPENAI_API_KEY=gsk_...
#   OPENAI_BASE_URL=https://api.groq.com/openai/v1
#   OPENAI_MODEL=llama-3.1-8b-instant
# OpenAI:
#   OPENAI_BASE_URL=https://api.openai.com/v1
#   OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=openai/gpt-oss-120b
OPENAI_TIMEOUT=30
# false only for local Windows if PHP SSL CA certs are missing (cURL error 60)
OPENAI_VERIFY_SSL=true

# Public Jitsi instance for in-app meetings (override for self-hosted)
JITSI_BASE_URL=https://meet.jit.si

# Queue — meeting notifications are sent in the background (run: php artisan queue:work)
QUEUE_CONNECTION=database

# Mail (log driver writes to storage/logs/laravel.log in local dev)
MAIL_MAILER=log
MAIL_FROM_ADDRESS=notifications@unischedule.local
MAIL_FROM_NAME="${APP_NAME}"

# Optional SMTP / Mailtrap for demo or UAT:
# MAIL_MAILER=smtp
# MAIL_HOST=sandbox.smtp.mailtrap.io
# MAIL_PORT=2525
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_ENCRYPTION=tls
